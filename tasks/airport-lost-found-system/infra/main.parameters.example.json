{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": { "value": "airportlfdemo" },
    "containerRegistryServer": { "value": "YOUR_REGISTRY.azurecr.io" },
    "containerRegistryUsername": { "value": "YOUR_REGISTRY_USERNAME" },
    "containerRegistryPassword": { "value": "REPLACE_WITH_SECURE_VALUE" },
    "backendImage": { "value": "YOUR_REGISTRY.azurecr.io/airport-lost-found-backend:latest" },
    "frontendImage": { "value": "YOUR_REGISTRY.azurecr.io/airport-lost-found-frontend:latest" },
    "postgresAdminPassword": { "value": "REPLACE_WITH_SECURE_VALUE" },
    "jwtSecret": { "value": "REPLACE_WITH_SECURE_VALUE" },
    "azureOpenAIEndpoint": { "value": "https://YOUR_OPENAI_RESOURCE.openai.azure.com/" },
    "azureOpenAIApiKey": { "value": "REPLACE_WITH_SECURE_VALUE" },
