name: Deploy Azure Container Apps

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  id-token: write
  contents: read

env:
  BACKEND_IMAGE_NAME: airport-lost-found-backend
  FRONTEND_IMAGE_NAME: airport-lost-found-frontend

jobs:
  test:
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_DB: airport_lost_found
          POSTGRES_USER: airport
          POSTGRES_PASSWORD: airport
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U airport -d airport_lost_found"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 10
      redis:
        image: redis:7-alpine
        ports:
          - 6379:6379
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 10
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install backend dependencies
        working-directory: backend
        run: pip install -r requirements.txt -r requirements-dev.txt

      - name: Run migration smoke test
        working-directory: backend
        env:
          DATABASE_URL: postgresql+psycopg://airport:airport@localhost:5432/airport_lost_found
          REDIS_URL: redis://localhost:6379/0
          JWT_SECRET: ci-test-secret
          USE_AZURE_SERVICES: "false"
        run: alembic upgrade head

      - name: Run backend tests
        working-directory: backend
        env:
          DATABASE_URL: postgresql+psycopg://airport:airport@localhost:5432/airport_lost_found
          REDIS_URL: redis://localhost:6379/0
          JWT_SECRET: ci-test-secret
          USE_AZURE_SERVICES: "false"
        run: |
          python -m compileall app
          pytest

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: npm
          cache-dependency-path: frontend/package-lock.json

      - name: Build frontend
        working-directory: frontend
        env:
          VITE_API_URL: http://localhost:8000
        run: |
          npm ci
          npm test

      - name: Docker build smoke tests
        run: |
          docker build -t airport-lost-found-backend:ci ./backend
          docker build --build-arg VITE_API_URL=http://localhost:8000 -t airport-lost-found-frontend:ci ./frontend

  deploy:
    runs-on: ubuntu-latest
    needs: test
    environment: production
    steps:
      - uses: actions/checkout@v4

      - name: Azure login
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}

      - name: Log in to Azure Container Registry
        run: az acr login --name "${{ vars.ACR_NAME }}"

      - name: Build and push backend
        run: |
          docker build -t "${{ vars.ACR_LOGIN_SERVER }}/${BACKEND_IMAGE_NAME}:${{ github.sha }}" ./backend
          docker push "${{ vars.ACR_LOGIN_SERVER }}/${BACKEND_IMAGE_NAME}:${{ github.sha }}"

      - name: Build and push frontend
        run: |
          docker build \
            --build-arg VITE_API_URL="${{ vars.BACKEND_PUBLIC_URL }}" \
            -t "${{ vars.ACR_LOGIN_SERVER }}/${FRONTEND_IMAGE_NAME}:${{ github.sha }}" \
            ./frontend
          docker push "${{ vars.ACR_LOGIN_SERVER }}/${FRONTEND_IMAGE_NAME}:${{ github.sha }}"

      - name: Deploy infrastructure
        run: |
          az group create --name "${{ vars.AZURE_RESOURCE_GROUP }}" --location "${{ vars.AZURE_LOCATION }}"
          az deployment group create \
            --resource-group "${{ vars.AZURE_RESOURCE_GROUP }}" \
            --template-file infra/main.bicep \
            --parameters \
              namePrefix="${{ vars.AZURE_NAME_PREFIX }}" \
              containerRegistryServer="${{ vars.ACR_LOGIN_SERVER }}" \
              containerRegistryUsername="${{ secrets.ACR_USERNAME }}" \
              containerRegistryPassword="${{ secrets.ACR_PASSWORD }}" \
              backendImage="${{ vars.ACR_LOGIN_SERVER }}/${BACKEND_IMAGE_NAME}:${{ github.sha }}" \
              frontendImage="${{ vars.ACR_LOGIN_SERVER }}/${FRONTEND_IMAGE_NAME}:${{ github.sha }}" \
              postgresAdminPassword="${{ secrets.POSTGRES_ADMIN_PASSWORD }}" \
              jwtSecret="${{ secrets.JWT_SECRET }}" \
              azureOpenAIEndpoint="${{ vars.AZURE_OPENAI_ENDPOINT }}" \
              azureOpenAIApiKey="${{ secrets.AZURE_OPENAI_API_KEY }}" \
              azureOpenAIChatDeployment="${{ vars.AZURE_OPENAI_CHAT_DEPLOYMENT }}" \
              azureOpenAIEmbeddingDeployment="${{ vars.AZURE_OPENAI_EMBEDDING_DEPLOYMENT }}" \
              azureVisionEndpoint="${{ vars.AZURE_AI_VISION_ENDPOINT }}" \
              azureVisionKey="${{ secrets.AZURE_AI_VISION_KEY }}" \
              azureCommunicationConnectionString="${{ secrets.AZURE_COMMUNICATION_CONNECTION_STRING }}" \
              azureCommunicationEmailSender="${{ vars.AZURE_COMMUNICATION_EMAIL_SENDER }}" \
              azureCommunicationSmsSender="${{ vars.AZURE_COMMUNICATION_SMS_SENDER }}"
