# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=your-gpt-4o-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-text-embedding-3-small-deployment-name

# Neo4j
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# App defaults
SAMPLE_PDF_PATH=education-15-00343-v2.pdf
CHROMA_COLLECTION=pdf_chunks
CHUNK_TARGET_CHARS=1800
CHUNK_OVERLAP_CHARS=250
EXTRACTION_MAX_CHARS=9000
RETRIEVAL_TOP_K=5
GRAPH_LIMIT=25
