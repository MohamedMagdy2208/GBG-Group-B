# Copy this file to .streamlit/secrets.toml and fill in your values.
# You can also use the sidebar Save configuration button to create/update that file.
# Do not put real secrets in this example file.
# The app also accepts the same values from environment variables or sidebar overrides.

azure_endpoint = "https://<resource>.cognitiveservices.azure.com/"
azure_api_key = "<document-intelligence-key>"

# Required for custom model build and usable for upload when it has write permission.
storage_container_url = "https://<account>.blob.core.windows.net/<container>?<sas>"

# Optional upload fallback. Model build still requires storage_container_url.
storage_connection_string = ""
storage_container_name = ""

custom_model_id = ""
