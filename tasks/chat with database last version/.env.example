# Required - Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Optional - Azure OpenAI embeddings for dynamic few-shot retrieval
USE_EMBEDDING_RETRIEVAL=false
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
FEWSHOT_TOP_K=8

# Required - Database
# Local Docker PostgreSQL default:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chinook

# Optional - result/answer row cap
MAX_RESULT_ROWS=50
MAX_CHAT_HISTORY_MESSAGES=6
MAX_CHAT_HISTORY_CHARS=1200

# Optional - LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=chinook-chatbot
